# Convex backend URL (defaults to Convex Cloud if not set)
NEXT_PUBLIC_CONVEX_URL=https://outstanding-dalmatian-787.convex.cloud

# Anthropic API key (used by Convex for AI resume analysis)
ANTHROPIC_API_KEY=

# AWS deployment variables (used by buildspec.yml)
AWS_ACCOUNT_ID=
AWS_DEFAULT_REGION=us-east-1
IMAGE_REPO_NAME=ietires-web
IMAGE_TAG=latest
